# =============================================================================
# cfMeDIP-seq Workflow .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Data files (large, should not be in repo)
# -----------------------------------------------------------------------------
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bam
*.bam.bai
*.sam
*.cram
*.vcf
*.vcf.gz
*.bed
*.bigwig
*.bw
*.bedGraph
*.wig

# -----------------------------------------------------------------------------
# Reference genomes and indices
# -----------------------------------------------------------------------------
resources/genomes/
resources/bsgenome/
*.fa
*.fa.fai
*.fasta
*.fasta.fai
*.dict
*.amb
*.ann
*.bwt
*.pac
*.sa
*.bt2
*.bt2l

# -----------------------------------------------------------------------------
# Output directories (generated data)
# -----------------------------------------------------------------------------
output/
outputs/
results/
work/logs/
work/trimmed/
work/aligned/
work/sorted/
work/umi_extracted/
work/spikein_bsgenome/

# -----------------------------------------------------------------------------
# Snakemake
# -----------------------------------------------------------------------------
.snakemake/
*.snakemake.log

# -----------------------------------------------------------------------------
# Conda environments (auto-created)
# -----------------------------------------------------------------------------
.conda/
conda_envs/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# R
# -----------------------------------------------------------------------------
.Rhistory
.Rapp.history
.RData
.Ruserdata
*.Rproj.user/
.Rproj.user

# -----------------------------------------------------------------------------
# IDE and editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Logs and temporary files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.cache
logs/
temp/
tmp/

# -----------------------------------------------------------------------------
# Config files with sensitive/local paths (keep templates)
# -----------------------------------------------------------------------------
work/config.yaml
samplefiles/current_*.tsv
samplefiles/samples.tsv

# Keep template configs
!configfiles/config_template.yaml
!samplefiles/samples_template.tsv

# -----------------------------------------------------------------------------
# GUI (private - not for public repo)
# -----------------------------------------------------------------------------
gui/
scripts/gui/
install_desktop.sh
launch_medipipe.sh
medipipe.desktop

# -----------------------------------------------------------------------------
# MCP (optional components)
# -----------------------------------------------------------------------------
mcp/

# -----------------------------------------------------------------------------
# Warp workflows (local config)
# -----------------------------------------------------------------------------
.warp/

# -----------------------------------------------------------------------------
# Documentation builds
# -----------------------------------------------------------------------------
docs/_build/
site/

# -----------------------------------------------------------------------------
# Test data
# -----------------------------------------------------------------------------
test_data/
tests/data/

# -----------------------------------------------------------------------------
# Results and QC reports (not for public repo)
# -----------------------------------------------------------------------------
qc_reports/
*_qc_report.*
comprehensive_qc_report.*

# -----------------------------------------------------------------------------
# Temporary run scripts
# -----------------------------------------------------------------------------
run_*.sh
!run_workflow.sh

# -----------------------------------------------------------------------------
# Archive files
# -----------------------------------------------------------------------------
*.zip

# -----------------------------------------------------------------------------
# Symlinks to local resources
# -----------------------------------------------------------------------------
resources

# -----------------------------------------------------------------------------
# Local sync/backup scripts
# -----------------------------------------------------------------------------
backup_to_github.sh
sync_to_github.sh
